extends layout.jade

block content
  h1= title
  p Welcome, it's #{time}
  p: img(src="/images/nyan.gif", title="nyan cat")

  hr

  h2 Send a Message (Web → API → DB Write)
  form(method="POST", action="/")
    input(type="text", name="message", placeholder="Type your message here...", required, style="padding: 8px; width: 300px; margin-right: 8px;")
    button(type="submit", style="padding: 8px 16px;") Send

  hr

  h2 Messages from DB (Web → API → DB Read)
  if messages && messages.length > 0
    table(border="1", cellpadding="8", cellspacing="0")
      thead
        tr
          th ID
          th Message
          th Created At
      tbody
        each msg in messages
          tr
            td= msg.id
            td= msg.text
            td= msg.created_at
  else
    p No messages yet. Use the form above to add one!
